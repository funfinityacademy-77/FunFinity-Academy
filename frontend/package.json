{
  "name": "funfinity-academy",
  "version": "1.0.0",
  "description": "Autonomous Agentic Ecosystem - Silicon Valley Level Educational Platform",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite --port 8080 --host",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "build:widget": "cd frontend && vite build --config vite.widget.config.ts",
    "lint": "eslint frontend/src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint frontend/src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check \"frontend/src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "clean": "rimraf dist",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create funfinity-db",
    "d1:execute": "wrangler d1 execute funfinity-db --local --file=./schema.sql"
  },
  "keywords": [
    "education",
    "ai",
    "autonomous",
    "agents",
    "learning",
    "react",
    "typescript",
    "liquid-glass",
    "gamification",
    "real-time",
    "silicon-valley",
    "funfinity",
    "academy"
  ],
  "author": {
    "name": "FunFinity Academy",
    "email": "info@funfinityacademy.com",
    "url": "https://funfinityacademy.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/funfinityacademy/autonomous-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/funfinityacademy/autonomous-ecosystem/issues"
  },
  "homepage": "https://funfinityacademy.com",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
