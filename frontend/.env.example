# Supabase Configuration (REQUIRED - Set in Vercel Environment Variables)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Admin Password (for admin account access)
VITE_ADMIN_PASSWORD=your_secure_admin_password_here

# Database Configuration (for local development only)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=funfinity_academy
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here

# Twilio Configuration (for emergency notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
EMERGENCY_NUMBERS=+1234567890,+0987654321
EMERGENCY_ENABLED=false

# OpenAI Configuration (for AI features)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Vercel Analytics (optional)
VITE_VERCEL_ANALYTICS_ID=your_vercel_analytics_id_here
